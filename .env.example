# 三角洲行动物价捕获分析 - 环境变量示例
# 复制本文件为 .env 并填入真实密钥（.env 已被 .gitignore 忽略，请勿提交）

# 三角洲行动物价 API 密钥（数据采集）
DF_API_KEY=your_delta_force_api_key

# DeepSeek API 密钥（公告趋势分析 / OCR + LLM）
DEEPSEEK_API_KEY=your_deepseek_api_key

# ---- 以下为可选项，均有默认值，可按需覆盖 ----
# Web 服务端口
# PORT=3000
# Python 解释器路径
# PYTHON=python
# 单子弹 CSV 目录（相对启动 node 进程的工作目录解析；不设置时默认 <仓库根>/Datasets/Datasets）
# BULLET_DATA_DIR=../Datasets/Datasets
# 倒卖计划总仓位
# SLOTS_TOTAL=1100
# 卖出手续费率
# SELL_FEE_RATE=0.15
# 策略档位（aggressive / balanced / conservative）
# PLAN_STRATEGY=aggressive
